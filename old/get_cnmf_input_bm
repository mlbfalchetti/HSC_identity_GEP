counts <- GetAssayData(seurat, assay = "RNA", layer = "counts")
load(file = "C:/Users/marce/OneDrive/Área de Trabalho/bch/m_falchetti/useful_data/protein_coding_genes.RData")
to_keep <- setdiff(
  intersect(rownames(counts), protein_coding_genes),
  grep("^RPS|^RPL|^MT-", rownames(counts), value = TRUE, ignore.case = TRUE)
