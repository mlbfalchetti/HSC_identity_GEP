library(Seurat)

#-- hpc young 1
data <- Read10X(data.dir = "C:/Users/marce/OneDrive/Área de Trabalho/bch/m_falchetti/raw_files/sk_2022/yBM1_hpc/")
names(data)
seurat <- CreateSeuratObject(counts = data[["Gene Expression"]], min.cells = 3, min.features = 200)
adt <- data[["Antibody capture"]]
head(rownames(adt))
seurat <- subset(seurat, cells = intersect(colnames(seurat), colnames(adt)))
adt <- adt[, intersect(colnames(seurat), colnames(adt))]
seurat[["ADT"]] <- CreateAssayObject(counts = adt)
DefaultAssay(seurat) <- "RNA"
seurat[["percent.mt"]] <- PercentageFeatureSet(seurat, pattern = "^MT-")
VlnPlot(seurat, features = c("nFeature_RNA", "nCount_RNA", "percent.mt"), ncol = 3)
seurat <- subset(seurat, subset = nFeature_RNA > 200 & nFeature_RNA < 6000 & percent.mt < 15)
seurat <- SCTransform(seurat, verbose = FALSE)
seurat <- RunPCA(seurat, reduction.name = "pca_rna")
DefaultAssay(seurat) <- "ADT"
seurat <- NormalizeData(seurat, normalization.method = "CLR", margin = 2)
seurat <- ScaleData(seurat)
seurat <- RunPCA(seurat, reduction.name = "pca_adt", features = rownames(seurat[["ADT"]]))
seurat <- FindMultiModalNeighbors(seurat, reduction.list = list("pca_rna", "pca_adt"), dims.list = list(1:30, 1:18))
seurat <- RunUMAP(seurat, nn.name = "weighted.nn", reduction.name = "wnn.umap")
seurat <- FindClusters(seurat, graph.name = "wsnn", resolution = 0.6)
DimPlot(seurat, reduction = "wnn.umap", group.by = "seurat_clusters", label = TRUE)
DefaultAssay(seurat) <- "ADT"
FeaturePlot(seurat, reduction = "wnn.umap", features = c("ADT-CD34", "ADT-CD38", "ADT-CD45RA", "ADT-CD90", "ADT-CD49F"))
DimPlot(seurat, reduction = "wnn.umap", group.by = "seurat_clusters", label = TRUE) + FeaturePlot(seurat, reduction = "wnn.umap", features = c("ADT-CD34", "ADT-CD38", "ADT-CD45RA", "ADT-CD90", "ADT-CD49F"))
DefaultAssay(seurat) <- "SCT"
Idents(seurat) <- "seurat_clusters"
tmp <- FindMarkers(seurat, ident.1 = "0")
tmp <- tmp[which(tmp$avg_log2FC > 1 & tmp$p_val_adj < 0.05), ]
round(sum(c("AVP", "HLF", "FOS", "JUN", "CD164", "MECOM", "MLLT3", "MYCT1", "SPINK2") %in% rownames(tmp)) / 9 * 100, digits = 1)
c("AVP", "HLF", "FOS", "JUN", "CD164", "MECOM", "MLLT3", "MYCT1", "SPINK2")[c("AVP", "HLF", "FOS", "JUN", "CD164", "MECOM", "MLLT3", "MYCT1", "SPINK2") %in% rownames(tmp)]
seurat$hsc <- ifelse(seurat$seurat_clusters == "0", "hsc", "other")
